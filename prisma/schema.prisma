generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Seeded national-ID lookup table. Swap for real Sahel/PACI SSO later
/// by replacing the lookup in src/lib/identity.ts only.
model Citizen {
  civilId String @id
  name    String
}

model Declaration {
  id        Int      @id @default(autoincrement())
  civilId   String   @unique
  name      String
  mobile    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  animalGroups    AnimalGroup[]
  audit           Audit?
  revisions       DeclarationRevision[]
  soloAssignments Assignment[]          @relation("SoloAssignment")
}

model DeclarationRevision {
  id            Int      @id @default(autoincrement())
  declarationId Int
  revisedAt     DateTime @default(now())
  mobile        String
  locations     Json

  declaration Declaration @relation(fields: [declarationId], references: [id], onDelete: Cascade)

  @@index([declarationId])
}

model AnimalGroup {
  id            Int        @id @default(autoincrement())
  declarationId Int
  animalType    AnimalType

  declaration Declaration  @relation(fields: [declarationId], references: [id], onDelete: Cascade)
  locations   FarmLocation[]

  @@index([declarationId])
}

model FarmLocation {
  id             Int            @id @default(autoincrement())
  animalGroupId  Int
  gatheringPoint GatheringPoint
  latitude       Float
  longitude      Float
  locationLink   String
  chippedCount   Int
  males          Int
  females        Int
  numTenders     Int

  animalGroup AnimalGroup @relation(fields: [animalGroupId], references: [id], onDelete: Cascade)

  @@index([animalGroupId])
}

model Audit {
  id            Int      @id @default(autoincrement())
  declarationId Int      @unique
  createdAt     DateTime @default(now())

  declaration   Declaration        @relation(fields: [declarationId], references: [id], onDelete: Cascade)
  animalResults AuditAnimalResult[]
}

model AuditAnimalResult {
  id                Int             @id @default(autoincrement())
  auditId           Int
  animalType        AnimalType
  siteIndex         Int             @default(0)
  violationStatus   ViolationStatus
  differenceReasons Json
  locationLink      String
  latitude          Float?
  longitude         Float?
  manualCount       Int?

  audit    Audit         @relation(fields: [auditId], references: [id], onDelete: Cascade)
  readings ChipReading[]

  @@unique([auditId, animalType, siteIndex])
  @@index([auditId])
}

model ChipReading {
  id                   Int      @id @default(autoincrement())
  animalResultId       Int
  readAt               DateTime
  chipNumber           String
  rawChip              String
  flaggedSymbol        Boolean  @default(false)
  flaggedProximity     Boolean  @default(false)
  flaggedMultipleChips Boolean  @default(false)
  flaggedDoesntBelong  Boolean  @default(false)

  animalResult AuditAnimalResult @relation(fields: [animalResultId], references: [id], onDelete: Cascade)

  @@index([animalResultId])
}

enum GatheringPoint {
  WAFRA
  JAHRA
  KABD
  ABDALI
  MINA_ABDULLAH
}

enum AnimalType {
  SHEEP_GOATS
  CAMELS
  COWS
}

enum ViolationStatus {
  NONE
  VIOLATION
}

enum GroupType {
  SMALL
  SOLO
}

model Supervisor {
  id          Int          @id @default(autoincrement())
  civilId     String       @unique
  name        String
  assignments Assignment[]
}

model Assignment {
  id                Int            @id @default(autoincrement())
  supervisorId      Int
  animalType        AnimalType
  gatheringPoint    GatheringPoint
  groupType         GroupType
  soloDeclarationId Int?
  groupKey          String         @unique
  createdAt         DateTime       @default(now())

  supervisor      Supervisor   @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
  soloDeclaration Declaration? @relation("SoloAssignment", fields: [soloDeclarationId], references: [id], onDelete: Cascade)

  @@index([supervisorId])
  @@index([animalType, gatheringPoint])
}

enum DifferenceReason {
  NOT_CHIPPED
  UNREADABLE
  MULTIPLE_CHIPS
  UNREGISTERED_TRADE
  SLAUGHTER_DEATH
  OTHER
}
